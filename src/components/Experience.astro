---
const experiences = [
  {
    company: 'Tech Solutions Inc.',
    role: 'Senior Frontend Developer',
    period: '2022 - Presente',
    description: 'Liderazgo en el desarrollo de interfaces web utilizando React y Next.js. Optimización de rendimiento y accesibilidad.',
  },
  {
    company: 'Creative Agency',
    role: 'Full Stack Developer',
    period: '2020 - 2022',
    description: 'Desarrollo de sitios web a medida para diversos clientes. Implementación de backend con Node.js y bases de datos NoSQL.',
  },
  {
    company: 'StartUp Hub',
    role: 'Junior Web Developer',
    period: '2018 - 2020',
    description: 'Colaboración en el desarrollo inicial de MVPs. Mantenimiento y depuración de bugs en plataformas existentes.',
  },
];
---

<section id="experiencia" class="py-20">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold mb-12">Experiencia Profesional</h2>
    <div class="space-y-8">
      {experiences.map((exp) => (
        <div class="relative pl-8 border-l border-border pb-8 last:pb-0">
          <div class="absolute left-[-5px] top-0 h-2.5 w-2.5 rounded-full bg-primary" />
          <div class="flex flex-col md:flex-row md:items-baseline md:justify-between mb-2">
            <h3 class="text-xl font-bold">{exp.role}</h3>
            <span class="text-sm font-medium text-muted-foreground bg-secondary px-3 py-1 rounded-full">{exp.period}</span>
          </div>
          <p class="text-lg font-medium text-primary mb-3">{exp.company}</p>
          <p class="text-muted-foreground leading-relaxed">{exp.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
